broker:
  name: 楽天証券
  account_type: 一般口座  # 一般口座 / 特定口座源泉あり / 特定口座源泉なし / NISA

fees:
  us_stock:
    rate: 0.00495       # 約定代金×0.495%
    min_usd: 0
    max_usd: 22
    sec_fee: 0.0000206  # 売却時のみ
  jp_stock:
    rate: 0             # ゼロコース等
  asean_stock:
    rate: 0.011         # 約定代金×1.1%
  fx:
    realtime_spread: 0  # リアルタイム為替: 0銭
    scheduled_spread: 0 # 定時為替: 0銭

tax:
  capital_gains_rate: 0.20315  # 所得税15.315% + 住民税5%
  needs_filing: true           # 一般口座→true
  realized_losses_ytd: 0       # 今年の確定損失額（損益通算用、手動更新）

screening:
  excluded_regions: [kr, tw, europe, uk]  # 証券会社で取扱なし
  preferred_regions: [japan, us, sg, hk, id]  # 取扱あり
