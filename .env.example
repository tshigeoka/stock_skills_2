# Stock-Skills Environment Variables (KIK-574)
# Copy to .env and fill in your values.
# See config/thresholds.yaml for business logic parameters.

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_MODE=full                # off / summary / full

# --- TEI (Text Embeddings Inference) ---
TEI_URL=http://localhost:8081

# --- Grok API (xAI) - X Search + Sentiment Analysis (KIK-359) ---
# Get your API key from https://console.x.ai/
XAI_API_KEY=xai-xxxxxxxxxxxxx

# --- Perplexity API - Sonar Pro / Deep Research (KIK-426) ---
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxx

# --- Anthropic API (AI graph linking, KIK-434) ---
ANTHROPIC_API_KEY=

# --- Linear Integration ---
LINEAR_ENABLED=off
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_PROJECT_ID=

# --- Context Freshness ---
CONTEXT_FRESH_HOURS=24         # Hours within which data is "FRESH"
CONTEXT_RECENT_HOURS=168       # Hours within which data is "RECENT" (7 days)
